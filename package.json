{
  "name": "libretro-wasm-host",
  "version": "0.1.0",
  "description": "Minimal libretro frontend capable of loading WebAssembly cores",
  "type": "module",
  "main": "src/libretro-host.js",
  "exports": {
    ".": "./src/libretro-host.js"
  },
  "keywords": [
    "libretro",
    "wasm",
    "frontend"
  ],
  "license": "MIT",
  "scripts": {
    "cores": "cmake -B build -G Ninja && cmake --build build",
    "start": "npx -y live-server web --mount=/cores:./build/cores/",
    "prestart": "npm run cores"
  }
}
